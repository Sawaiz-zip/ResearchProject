# ── Option 1: Groq (free, no credit card — https://console.groq.com) ─────────
# Best free choice: instant signup, 30 req/min, Llama 3.3 70B
# LLM_API_KEY=gsk_...
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_CHEAP_MODEL=llama-3.3-70b-versatile
# LLM_STRONG_MODEL=llama-3.3-70b-versatile

# ── Option 2: Google Gemini (free, no credit card — https://aistudio.google.com) ──
# LLM_API_KEY=AIza...
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_CHEAP_MODEL=gemini-2.0-flash
# LLM_STRONG_MODEL=gemini-2.0-flash

# ── Option 3: Ollama (local, unlimited — https://ollama.com) ──────────────────
# Run: ollama pull llama3.1  (one-time, ~5 GB)
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_CHEAP_MODEL=llama3.1
# LLM_STRONG_MODEL=llama3.1

# ── Option 4: Anthropic Claude (intended model — https://console.anthropic.com) ─
# ANTHROPIC_API_KEY=sk-ant-...

# ── LangSmith tracing (optional) ──────────────────────────────────────────────
# LANGSMITH_API_KEY=...
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=S6-ReKI-1
